DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME
ADMIN_PASSWORD=change-me-to-a-strong-password
APP_URL=https://your-domain-or-subdomain
AUTH_COOKIE_SECRET=replace-with-a-long-random-string
DATA_ENCRYPTION_KEY=replace-with-a-different-long-random-string
SITE_CHECK_BATCH_SIZE=10
SITE_CHECK_INTERVAL_MS=300000
SERVER_CHECK_INTERVAL_MS=300000
SITE_INITIAL_DELAY_MS=35000
SERVER_INITIAL_DELAY_MS=20000
SITE_JOB_LOCK_TTL_SEC=1800
SERVER_JOB_LOCK_TTL_SEC=120
SERVER_HEARTBEAT_TTL_SEC=180
MONITOR_INTERNAL_SECRET=replace-with-a-long-random-string
